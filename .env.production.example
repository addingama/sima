APP_NAME="SIMA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://sima.example.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — JSON untuk agregator log (Datadog, Loki, CloudWatch)
LOG_CHANNEL=stack
LOG_STACK=json,daily
LOG_LEVEL=info
LOG_DAILY_DAYS=30

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sima
DB_USERNAME=sima
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Session, cache, queue — Redis wajib di produksi
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.sima.example.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=sima_prod_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@sima.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Frontend — same origin via NGINX (path /api)
FRONTEND_URL=https://sima.example.com
NEXT_PUBLIC_API_URL=/api
SANCTUM_STATEFUL_DOMAINS=sima.example.com
SANCTUM_TOKEN_EXPIRATION=720

# Ops
RUN_MIGRATIONS=true
SIMA_HTTP_PORT=80
SIMA_BACKUP_DIR=storage/backups

# Optional: S3-compatible storage for attachments
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=sima-attachments
# AWS_URL=
