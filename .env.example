APP_NAME="SIMA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8080

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging: produksi disarankan LOG_STACK=json,daily LOG_LEVEL=info
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# Database — lokal tanpa Docker: mysql/mariadb. CI/tests: sqlite :memory:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sima
DB_USERNAME=sima
DB_PASSWORD=sima_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=sima_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@sima.local"
MAIL_FROM_NAME="${APP_NAME}"

# Frontend (Next.js) — CORS & Sanctum SPA
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SANCTUM_TOKEN_EXPIRATION=720

# Docker compose overrides (optional)
SIMA_HTTP_PORT=8080
SIMA_MYSQL_PORT=3306
SIMA_REDIS_PORT=6379
SIMA_BACKUP_DIR=storage/backups

VITE_APP_NAME="${APP_NAME}"
